#!/bin/bash
set -e

ask() {
    local prompt="$1 [Y/n] "
    local default=yes
    local answer
    read -r -p "$prompt" answer
    case "$answer" in
        [nN]|[nN][oO]) return 1 ;;
        *) return 0 ;;
    esac
}

echo "========================================"
echo "  yadm bootstrap - 环境初始化"
echo "========================================"
echo ""

echo "==> 安装核心基础工具..."
bash "$HOME/.config/yadm/bootstrap.d/01-packages.sh"

echo ""
echo "--- 可选安装 ---"

ask "安装 JetBrains Mono 字体"    && bash "$HOME/.config/yadm/bootstrap.d/02-fonts.sh"
ask "安装 Neovim"                 && bash "$HOME/.config/yadm/bootstrap.d/03-neovim.sh"
ask "安装 zsh + p10k + zim"       && bash "$HOME/.config/yadm/bootstrap.d/04-zsh.sh"
ask "安装 tmux + TPM"             && bash "$HOME/.config/yadm/bootstrap.d/05-tmux.sh"
ask "安装 kitty"                  && bash "$HOME/.config/yadm/bootstrap.d/06-kitty.sh"

echo ""
echo "所有 bootstrap 脚本执行完成！"
